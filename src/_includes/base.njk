<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#FEFF35">
  <title>{% if title %}{{ title }} — {{ site.shortTitle }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/assets/css/site.css">
</head>
<body>

  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-brand" aria-label="every*where home">every*where</a>
      {% include "nav.njk" %}
    </div>
  </header>

  <main class="site-main">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="site-footer-inner">
      <p class="acknowledgment">{{ site.acknowledgment }}</p>
      <p class="copyright">&copy; Adelaide Design Week {{ site.year }}</p>
    </div>
  </footer>

</body>
</html>
